@model ProductsWithRouting.Models.Product

@{
    ViewData["Title"] = "Create";
}
<div class="bg-dark text-white rounded p-3">
<h1>Create</h1>

<h4>Product</h4>
<hr />
@if (ViewBag.ErrorMessage != null)
{
    <div class="h4 pb-2 mb-4 text-danger border-bottom border-danger">
            Incorrect data, all fields except ID must be filled in manually
    </div>

    <div class="alert alert-danger d-flex align-items-center mt-3" role="alert">
        <span class="mr-2">Error:</span>
        <div>@ViewBag.ErrorMessage</div>
    </div>
}
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="Id" class="control-label"></label>
                <input asp-for="Id" class="form-control border-success  form-control" readonly />
                <span asp-validation-for="Id" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Name" class="control-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Description" class="control-label"></label>
                <input asp-for="Description" class="form-control" />
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
</div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
